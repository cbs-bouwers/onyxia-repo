{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "octopus": {
      "title": "Octopus",
      "type": "object",
      "properties": {
        "name": {
            "type": "string",
            "description": "user name for octopus",
            "default": "",
            "x-onyxia": {
                "overwriteDefaultWith": "{{octopus.name}}"
            },
            "hidden": {
                "value": false,
                "path": "octopus/enabled"
            }
        },
        "email": {
            "type": "string",
            "description": "user email for octopus",
            "default": "",
            "x-onyxia": {
                "overwriteDefaultWith": "{{octopus.email}}"
            },
            "hidden": {
                "value": false,
                "path": "octopus/enabled"
            }
        },
        "image": {
          "title": "Used files",
          "type": "object",
          "properties": {
            "pullPolicy": {
              "title": "Select files",
              "type": "string",
              "default": "CBA002",
              "enum": [
                "CBA002",
                "DAC300",
                "PROTO"
              ]
            },
            "custom": {
              "title": "Decode values",
              "type": "object",
              "properties": {
                "enabled": {
                  "title": "Needs decodeing?",
                  "type": "boolean",
                  "default": false
                }
              }
            }
          }
        }
      }
    }
  }
}
