{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "properties": {
    "ingress": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string",
          "default": "",
          "x-onyxia": {        
            "overwriteDefaultWith": "{{project.id}}-{{k8s.randomSubdomain}}-0.{{k8s.domain}}",
            "hidden": true
          }
        }
      }
    }
    "s3": {
      "description": "Configuration for S3 Object Storage",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable S3 Mount",
          "description": "Mount S3 as a local filesystem inside the PSPP workspace",
          "default": true
        }
      }
    }
  }
}
